<Window x:Class="Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Converters"
        xmlns:vm="clr-namespace:Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.ViewModels"
        xmlns:views="clr-namespace:Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views"
        mc:Ignorable="d"
        Title="Sistema de Control de Calificaciones - José Ma. Morelos y Pavón"
        WindowState="Normal"
        Width="1108"
        Height="689"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B365D" CornerRadius="0,0,10,10" Panel.ZIndex="1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" VerticalAlignment="Center">
                    <Border.Background>
                        <ImageBrush ImageSource="/logo.jpg" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock Text='PREPARATORIA FEDERAL POR COOPERACIÓN "JOSÉ MA. MORELOS Y PAVÓN"' Foreground="White" FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="Control de Evaluaciones Continuas" Foreground="#A5B4FC" FontSize="12"
                               FontWeight="SemiBold" />
                </StackPanel>
                
                <Button Grid.Column="2"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Configuración"
                        Click="Configuracion_Click">

                    <TextBlock Text="⚙"
                               FontSize="22"
                               Foreground="White"
                               Opacity="0.8"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="15,10,15,5" CornerRadius="6" BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="USB:" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="#475569" Margin="0,0,5,0" />
                <TextBox Grid.Column="1" Text="{Binding RutaUsb, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Height="32" BorderBrush="#CBD5E1"
                         IsReadOnly="{Binding RutaUsbEditable, Converter={StaticResource InverseBoolConverter}}" />

                <Button Grid.Column="2" Content="Escanear" Command="{Binding EscanearUsbCommand}" Height="32"
                        Width="90" Margin="10,0,0,0" Background="#1B365D" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Grid.Column="3" Text="Archivo:" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="#475569" Margin="20,0,5,0" />
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding ArchivosDisponibles}"
                          SelectedItem="{Binding ArchivoSeleccionado}"
                          Height="32"
                          Width="450"
                          HorizontalAlignment="Left"
                          VerticalContentAlignment="Center" />

                <TextBlock Grid.Column="5" Text="Eval:" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="#475569" Margin="20,0,5,0" />
                <ComboBox Grid.Column="6" ItemsSource="{Binding EvaluacionesDisponibles}"
                          SelectedItem="{Binding EvaluacionSeleccionada}" Height="32" VerticalContentAlignment="Center" />

                <Button Grid.Column="7"
                        Content="Guardar"
                        Command="{Binding GuardarCommand}"
                        Height="32"
                        Width="90"
                        Margin="20,0,0,0"
                        Background="#16A34A"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Row="2" Margin="15,5,15,10" Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <views:TablaView />
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentView}" Value="Parciales">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <views:ParcialesView />
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <Border Grid.Row="3" Background="#E2E8F0">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Alumnos: " Foreground="#64748B" FontSize="11" FontWeight="Medium" />
                    <TextBlock Text="{Binding Alumnos.Count}" Foreground="#1E293B" FontSize="11" FontWeight="Bold" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Estado: Conectado" Foreground="#64748B" FontSize="11"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>