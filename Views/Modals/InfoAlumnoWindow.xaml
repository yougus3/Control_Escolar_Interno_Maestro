<Window x:Class="Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views.Modals.InfoAlumnoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📄 Información del Alumno" 
        Height="650" 
        Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <ImageSourceConverter x:Key="ImageSourceConverter"/>
    </Window.Resources>
    
    <Grid Background="#F5F6F8">
        <Border Background="White" 
                BorderBrush="#D7DEE8" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="16" 
                Margin="12">
            
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Header -->
                    <Border Background="#1B365D" 
                            CornerRadius="6" 
                            Padding="12" 
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄 " FontSize="18" />
                            <TextBlock Text="Información Completa del Alumno" 
                                       Foreground="White" 
                                       FontSize="16" 
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    
                    <!-- Foto y datos básicos -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Foto -->
                        <!-- Foto -->
                        <Border Grid.Column="0" 
                                Background="#F1F5F9" 
                                BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Width="100" 
                                Height="120"
                                HorizontalAlignment="Left">
                            <Image Source="{Binding FotoUrl}" 
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>
                        
                        <!-- Datos básicos (corregido: sin MultiBinding con Text duplicado) -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="{Binding Nombre}" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="#0F172A" 
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0" FontWeight="Bold" Foreground="#1B365D">
                                <Run Text="Matrícula: "/><Run Text="{Binding Matricula}"/>
                            </TextBlock>
                            <TextBlock FontWeight="Bold" Foreground="#1B365D">
                                <Run Text="Grupo: "/><Run Text="{Binding Grupo}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Separador -->
                    <Border Height="1" Background="#E2E8F0" Margin="0,8,0,16" />
                    
                    <!-- Calificaciones por parcial -->
                    <TextBlock Text="📊 Calificaciones por Parcial" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Foreground="#1B365D" 
                               Margin="0,0,0,12" />
                    
                    <!-- Tabla de calificaciones -->
                    <Border Background="#F8FAFC" 
                            BorderBrush="#E2E8F0" 
                            BorderThickness="1" 
                            CornerRadius="6" 
                            Padding="8" 
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Parcial" FontWeight="Bold" Foreground="#1B365D" Padding="4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Calificación" FontWeight="Bold" Foreground="#1B365D" Padding="4" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Asistencia" FontWeight="Bold" Foreground="#1B365D" Padding="4" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Estado" FontWeight="Bold" Foreground="#1B365D" Padding="4" />
                            
                            <Border Grid.Row="1" Grid.ColumnSpan="4" Height="1" Background="#E2E8F0" Margin="4,4,4,8" />
                            
                            <!-- P1 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="P1" FontWeight="SemiBold" Padding="4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding P1Calif}" Padding="4" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding P1Asistencia}" Padding="4" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding P1Estado}" Padding="4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding P1Estado}" Value="Aprobado">
                                                <Setter Property="Foreground" Value="#16A34A" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding P1Estado}" Value="Reprobado">
                                                <Setter Property="Foreground" Value="#EF4444" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding P1Estado}" Value="Reprobado por faltas">
                                                <Setter Property="Foreground" Value="#D97706" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- P2 -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="P2" FontWeight="SemiBold" Padding="4" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding P2Calif}" Padding="4" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding P2Asistencia}" Padding="4" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding P2Estado}" Padding="4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding P2Estado}" Value="Aprobado">
                                                <Setter Property="Foreground" Value="#16A34A" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding P2Estado}" Value="Reprobado">
                                                <Setter Property="Foreground" Value="#EF4444" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding P2Estado}" Value="Reprobado por faltas">
                                                <Setter Property="Foreground" Value="#D97706" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- P3 -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="P3" FontWeight="SemiBold" Padding="4" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding P3Calif}" Padding="4" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding P3Asistencia}" Padding="4" />
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding P3Estado}" Padding="4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding P3Estado}" Value="Aprobado">
                                                <Setter Property="Foreground" Value="#16A34A" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding P3Estado}" Value="Reprobado">
                                                <Setter Property="Foreground" Value="#EF4444" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding P3Estado}" Value="Reprobado por faltas">
                                                <Setter Property="Foreground" Value="#D97706" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- SEM -->
                            <Border Grid.Row="5" Grid.ColumnSpan="4" Height="1" Background="#E2E8F0" Margin="4,8,4,4" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="SEM" FontWeight="Bold" Foreground="#1B365D" Padding="4" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SEMCalif}" FontWeight="Bold" Padding="4" />
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="--" Padding="4" />
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding SEMEstado}" FontWeight="Bold" Padding="4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SEMEstado}" Value="Aprobado">
                                                <Setter Property="Foreground" Value="#16A34A" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SEMEstado}" Value="Reprobado">
                                                <Setter Property="Foreground" Value="#EF4444" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SEMEstado}" Value="Reprobado por faltas">
                                                <Setter Property="Foreground" Value="#D97706" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    
                    <!-- Promedio final -->
                    <Border Background="#EAF0F8" 
                            BorderBrush="#D7DEE8" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="12" 
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📈 Promedio Final: " 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1B365D" />
                            <TextBlock Text="{Binding PromedioFinal}" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="#16A34A" />
                            <TextBlock Text=" / 10" 
                                       FontSize="14" 
                                       Foreground="#64748B" 
                                       Margin="2,0,0,0" />
                        </StackPanel>
                    </Border>
                    
                    <!-- Botón cerrar -->
                    <Button Content="Cerrar" 
                            Width="100" 
                            Height="35"
                            HorizontalAlignment="Right"
                            Background="#1B365D" 
                            Foreground="White" 
                            FontWeight="Bold"
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Cerrar_Click" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>