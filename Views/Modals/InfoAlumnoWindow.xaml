<Window x:Class="Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views.Modals.InfoAlumnoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Información del Alumno" 
        Height="715" 
        Width="768
        "
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F1F5F9">
    
    <Window.Resources>
        <Geometry x:Key="UserIconGeometry">M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4s-4,1.79-4,4S9.79,12,12,12z M12,14c-2.67,0-8,1.34-8,4v2h16v-2 C20,15.34,14.67,14,12,14z</Geometry>
        <Style x:Key="BadgeBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E2E8F0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Aprobado">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Reprobado">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Reprobado por faltas">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Aprobado">
                    <Setter Property="Foreground" Value="#16A34A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Reprobado">
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Reprobado por faltas">
                    <Setter Property="Foreground" Value="#D97706"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Border Background="White" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Color="#94A3B8" Opacity="0.3" Direction="270"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1B365D" CornerRadius="12,12,0,0" Padding="20,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                            <Path Fill="White"
                                  Data="{StaticResource UserIconGeometry}"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <TextBlock Text="Expediente del Alumno" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
                    <StackPanel>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="110" Height="130" CornerRadius="8" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="2" Margin="0,0,20,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#CBD5E1" Opacity="0.4"/>
                                </Border.Effect>
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image x:Name="FotoAlumnoImage" 
                                           Stretch="Uniform" 
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>                                
                                </Border>
                            </Border>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Nombre}" FontSize="22" FontWeight="Bold" Foreground="#1B365D" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Matrícula:" FontWeight="SemiBold" Foreground="#64748B" Width="80" FontSize="16"/>
                                    <TextBlock Text="{Binding Matricula}" FontWeight="Bold" Foreground="#334155" FontSize="16"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Grupo:" FontWeight="SemiBold" Foreground="#64748B" Width="80" FontSize="16"/>
                                    <TextBlock Text="{Binding Grupo}" FontWeight="Bold" Foreground="#334155" FontSize="16"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Desglose de Evaluaciones" FontWeight="Bold" FontSize="16" Foreground="#1B365D" Margin="0,0,0,12"/>

                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/> 
                                </Grid.RowDefinitions>
                                
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="0" Grid.ColumnSpan="4" Background="#F8FAFC" CornerRadius="8,8,0,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"/>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Parcial" FontWeight="Bold" Foreground="#64748B" Padding="12"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Calificación" FontWeight="Bold" Foreground="#64748B" Padding="12"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Asistencia" FontWeight="Bold" Foreground="#64748B" Padding="12"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Estado" FontWeight="Bold" Foreground="#64748B" Padding="12"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="P1" FontWeight="Bold" Foreground="#334155" Padding="12" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding P1Calif}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" - NP" FontSize="14" FontWeight="Bold" Foreground="#D97706" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding P1Estado}" Value="Reprobado por faltas">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding P1Asistencia}" Foreground="#475569" Padding="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="1" Grid.Column="3" Margin="12,6">
                                    <Border Style="{StaticResource BadgeBorder}" Tag="{Binding P1Estado}">
                                        <TextBlock Text="{Binding P1Estado}" Style="{StaticResource BadgeText}"/>
                                    </Border>
                                </Border>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="P2" FontWeight="Bold" Foreground="#334155" Padding="12" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding P2Calif}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" - NP" FontSize="14" FontWeight="Bold" Foreground="#D97706" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding P2Estado}" Value="Reprobado por faltas">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding P2Asistencia}" Foreground="#475569" Padding="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="2" Grid.Column="3" Margin="12,6">
                                    <Border Style="{StaticResource BadgeBorder}" Tag="{Binding P2Estado}">
                                        <TextBlock Text="{Binding P2Estado}" Style="{StaticResource BadgeText}"/>
                                    </Border>
                                </Border>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="P3" FontWeight="Bold" Foreground="#334155" Padding="12" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding P3Calif}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" - NP" FontSize="14" FontWeight="Bold" Foreground="#D97706" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding P3Estado}" Value="Reprobado por faltas">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding P3Asistencia}" Foreground="#475569" Padding="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="3" Grid.Column="3" Margin="12,6">
                                    <Border Style="{StaticResource BadgeBorder}" Tag="{Binding P3Estado}">
                                        <TextBlock Text="{Binding P3Estado}" Style="{StaticResource BadgeText}"/>
                                    </Border>
                                </Border>

                                <!-- Fila PROM (Promedio de 3 Parciales) -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="PROM" FontWeight="Bold" Foreground="#1B365D" Padding="12" VerticalAlignment="Center" Background="#EFF6FF"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PromedioParciales}" FontSize="15" FontWeight="Bold" Foreground="#1B365D" Padding="12" VerticalAlignment="Center" Background="#EFF6FF"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="--" Foreground="#94A3B8" Padding="12" VerticalAlignment="Center" Background="#EFF6FF"/>
                                <Border Grid.Row="4" Grid.Column="3" Margin="12,6" Background="#EFF6FF">
                                    <Border Style="{StaticResource BadgeBorder}" Background="#DBEAFE">
                                        <TextBlock Text="Promedio Parciales" Foreground="#1E40AF" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Border>

                                <Border Grid.Row="5" Grid.ColumnSpan="4" Height="2" Background="#E2E8F0"/>

                                <Border Grid.Row="6" Grid.ColumnSpan="4" Background="#F1F5F9" CornerRadius="0,0,8,8"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="SEM" FontWeight="Black" Foreground="#0F172A" Padding="12" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SEMCalif}" FontSize="16" FontWeight="Black" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    <TextBlock Text=" - NP (NO SE PRESENTÓ)" FontSize="14" FontWeight="Bold" Foreground="#D97706" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SEMEstado}" Value="Reprobado por faltas">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="--" Foreground="#94A3B8" Padding="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="6" Grid.Column="3" Margin="12,6">
                                    <Border Style="{StaticResource BadgeBorder}" Tag="{Binding SEMEstado}">
                                        <TextBlock Text="{Binding SEMEstado}" Style="{StaticResource BadgeText}"/>
                                    </Border>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Border HorizontalAlignment="Left" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="16,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Promedio Final:" FontWeight="SemiBold" Foreground="#1E3A8A" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PromedioFinal}" FontWeight="Black" Foreground="#2563EB" FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Text=" / 10" FontWeight="Medium" Foreground="#93C5FD" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                
                                <TextBlock Text=" - NP (NO SE PRESENTÓ)" FontWeight="Bold" Foreground="#DC2626" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SEMEstado}" Value="Reprobado por faltas">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Content="Cerrar" 
                                HorizontalAlignment="Right" 
                                Width="120" 
                                Height="40" 
                                Background="#1B365D" 
                                Foreground="White" 
                                FontSize="14" 
                                FontWeight="Bold" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Click="Cerrar_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>