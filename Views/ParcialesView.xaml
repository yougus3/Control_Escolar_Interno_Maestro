<UserControl x:Class="Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views.ParcialesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.openxmlformats.org/expression/blend/2008"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             d:DesignHeight="680"
             d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Paleta principal -->
        <SolidColorBrush x:Key="AppBlue" Color="#1B365D" />
        <SolidColorBrush x:Key="AppBlueDark" Color="#172F52" />
        <SolidColorBrush x:Key="AppBlueSoft" Color="#EFF6FF" />
        <SolidColorBrush x:Key="AppBlueSoftBorder" Color="#BFDBFE" />
        <SolidColorBrush x:Key="AppSurface" Color="White" />
        <SolidColorBrush x:Key="AppSurfaceSoft" Color="#F8FAFC" />
        <SolidColorBrush x:Key="AppLine" Color="#D7DEE8" />
        <SolidColorBrush x:Key="AppTextPrimary" Color="#0F172A" />
        <SolidColorBrush x:Key="AppTextSecondary" Color="#64748B" />

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Botón base azul -->
        <Style x:Key="BlueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppBlue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppBlueDark}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón icono / transparente -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF0F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox redondeado -->
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AppBlue}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox tipo tarjeta -->
        <Style x:Key="CardGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource AppBlue}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid Margin="0,10,0,0">
                            <Border Background="White"
                                    BorderBrush="{StaticResource AppLine}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="{StaticResource AppBlue}"
                                            CornerRadius="11"
                                            Padding="10,6"
                                            Margin="10,-14,10,0"
                                            HorizontalAlignment="Left"
                                            TextElement.Foreground="White"
                                            TextElement.FontWeight="Bold"
                                            TextElement.FontSize="13">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True" />
                                    </Border>

                                    <ContentPresenter Grid.Row="1"
                                                      Margin="12,12,12,12" />
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Border de actividad -->
        <Style x:Key="ActividadBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="#FAFBFD" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Texto de suma de porcentajes -->
        <Style x:Key="SumaPorcText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1B365D" />
        </Style>

        <!-- Bloque azul para la calificación parcial -->
        <Style x:Key="BlueGradeBlock" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppBlueSoft}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBlueSoftBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BlueGradeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#1E3A8A" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F1F5F9">
        <Border Background="White"
                BorderBrush="#D7DEE8"
                BorderThickness="1"
                CornerRadius="12"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Background="#1B365D"
                        CornerRadius="10"
                        Padding="12,10"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Calificaciones Parciales"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,2,0,0">
                            <TextBlock Text="Asignatura: "
                                       Foreground="#D6E4FF"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding NombreMateria}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="  Evaluación: "
                                       Foreground="#D6E4FF"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="15,0,0,0" />
                            <TextBlock Text="{Binding NombreEvaluacion}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="15,0,0,0"
                                        Visibility="{Binding MostrarGrupo, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="  Grupo: "
                                           Foreground="#D6E4FF"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding GrupoAlumno}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Contenido principal -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <!-- COLUMNA IZQUIERDA -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Propiedades de Actividades -->
                        <GroupBox Header="Propiedades de Actividades"
                                  Style="{StaticResource CardGroupBoxStyle}">
                            <GroupBox.Resources>
                                <DataTemplate x:Key="ActividadTemplate">
                                    <Border x:Name="ActividadBorder">
                                        <StackPanel>
                                            <CheckBox Content="Actividad activa"
                                                      IsChecked="{Binding Activa, Mode=TwoWay}"
                                                      Click="ActividadActiva_Click" />

                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Nombre:"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="#334155" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Nombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="24"
                                                         FontSize="11"
                                                         VerticalContentAlignment="Center"
                                                         IsEnabled="{Binding Activa}"
                                                         Style="{StaticResource RoundedTextBoxStyle}"
                                                         TextChanged="ActividadProp_TextChanged" />
                                            </Grid>

                                            <TextBlock Grid.Column="0"
                                                       Grid.ColumnSpan="5"
                                                       Text="No es obligatorio"
                                                       FontSize="10"
                                                       Foreground="#64748B"
                                                       Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Activa}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="42" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Porc:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,4,0"
                                                           FontSize="11"
                                                           Foreground="#334155" />

                                                <TextBox x:Name="PorcBox"
                                                         Grid.Column="1"
                                                         Style="{StaticResource RoundedTextBoxStyle}"
                                                         Text="{Binding Porcentaje, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="24"
                                                         FontSize="11"
                                                         HorizontalContentAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         IsEnabled="{Binding Activa}"
                                                         MaxLength="3"
                                                         PreviewTextInput="Numeros_PreviewTextInput"
                                                         DataObject.Pasting="Numeros_Pasting"
                                                         TextChanged="ActividadProp_TextChanged" />

                                                <TextBlock Grid.Column="2"
                                                           Text="%"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,8,0"
                                                           FontSize="11"
                                                           Foreground="#334155" />

                                                <TextBlock Grid.Column="3"
                                                           Text="Puntaje Máx:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,4,0"
                                                           FontSize="11"
                                                           Foreground="#334155" />

                                                <TextBox Grid.Column="4"
                                                         Text="{Binding PuntajeMaximo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="24"
                                                         FontSize="11"
                                                         HorizontalContentAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         IsEnabled="{Binding Activa}"
                                                         MaxLength="3"
                                                         Style="{StaticResource RoundedTextBoxStyle}"
                                                         PreviewTextInput="Numeros_PreviewTextInput"
                                                         DataObject.Pasting="Numeros_Pasting"
                                                         TextChanged="ActividadProp_TextChanged" />
                                            </Grid>
                                        </StackPanel>

                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ActividadBorderStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activa}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#16A34A" />
                                                        <Setter Property="Background" Value="#ECFDF5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Activa}" Value="False">
                                                        <Setter Property="BorderBrush" Value="#DC2626" />
                                                        <Setter Property="Background" Value="#FFFBFA" />
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </GroupBox.Resources>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ContentControl Grid.Row="0"
                                                Grid.Column="0"
                                                Content="{Binding Actividades[0]}"
                                                ContentTemplate="{StaticResource ActividadTemplate}"
                                                Margin="2" />
                                <ContentControl Grid.Row="0"
                                                Grid.Column="1"
                                                Content="{Binding Actividades[1]}"
                                                ContentTemplate="{StaticResource ActividadTemplate}"
                                                Margin="2" />
                                <ContentControl Grid.Row="1"
                                                Grid.Column="0"
                                                Content="{Binding Actividades[2]}"
                                                ContentTemplate="{StaticResource ActividadTemplate}"
                                                Margin="2" />
                                <ContentControl Grid.Row="1"
                                                Grid.Column="1"
                                                Content="{Binding Actividades[3]}"
                                                ContentTemplate="{StaticResource ActividadTemplate}"
                                                Margin="2" />
                            </Grid>
                        </GroupBox>

                        <!-- Configuración de Asistencias -->
                        <GroupBox Grid.Row="1"
                                  Header="Configuración de Asistencias"
                                  Margin="0,5,0,0"
                                  Style="{StaticResource CardGroupBoxStyle}">
                            <Border BorderBrush="#D7DEE8"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,8"
                                    Margin="4"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <CheckBox Content="Evaluar asistencia en este parcial"
                                              IsChecked="{Binding AsistenciaActiva, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,0,0,8" />
                                    <WrapPanel Orientation="Horizontal"
                                               VerticalAlignment="Center"
                                               IsEnabled="{Binding AsistenciaActiva}">
                                        <TextBlock Text="Clases en el Parcial:"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Margin="0,0,5,5"
                                                   Foreground="#334155" />
                                        <TextBox Width="50"
                                                 Height="24"
                                                 FontSize="11"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Margin="0,0,15,5"
                                                 MaxLength="3"
                                                 Text="{Binding ClasesTotales, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource RoundedTextBoxStyle}"
                                                 PreviewTextInput="NumerosEnteros_PreviewTextInput"
                                                 DataObject.Pasting="Numeros_Pasting" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </GroupBox>

                        <!-- Suma de porcentajes -->
                        <Border Grid.Row="2"
                                Background="#EAF0F8"
                                BorderBrush="#D7DEE8"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding SumaPorcentajesTexto}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource SumaPorcText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SumaValida}" Value="False">
                                                    <Setter Property="Foreground" Value="#D97706" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Porcentaje acumulado mostrado arriba."
                                           FontSize="11"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- COLUMNA DERECHA -->
                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Lista de Alumnos -->
                        <GroupBox Header="Alumnos"
                                  Margin="0,0,0,5"
                                  Style="{StaticResource CardGroupBoxStyle}">
                            <ListBox ItemsSource="{Binding Alumnos}"
                                     SelectedItem="{Binding AlumnoSeleccionado, Mode=TwoWay}"
                                     SelectionChanged="Alumnos_SelectionChanged"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="4,2" />
                                        <Setter Property="Margin" Value="0,0,0,4" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FAFBFD"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="6"
                                                Margin="0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="40" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Matricula}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1E293B"
                                                           FontSize="14"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Nombre}"
                                                           Foreground="#334155"
                                                           FontSize="14"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Ver detalles del alumno"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Click="PapelButton_Click"
                                                        Tag="{Binding}">

                                                    <Viewbox Width="15" Height="15">
                                                        <Path Stroke="Black"
                                                              Fill="Transparent"
                                                              StrokeThickness="1.5"
                                                              Data="M6,2 L14,2 L18,6 L18,22 L6,22 Z
                                                                    M14,2 L14,6 L18,6
                                                                    M9,10 L15,10
                                                                    M9,13 L15,13
                                                                    M9,16 L13,16"/>
                                                    </Viewbox>

                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>

                        <!-- Botones de navegación -->
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,5">
                            <Button Content="Inicio"
                                    Command="{Binding InicioCommand}"
                                    Margin="0,0,4,0"
                                    MinWidth="72"
                                    Style="{StaticResource BlueButtonStyle}" />
                            <Button Content="Anterior"
                                    Command="{Binding AnteriorCommand}"
                                    Margin="0,0,4,0"
                                    MinWidth="72"
                                    Style="{StaticResource BlueButtonStyle}" />
                            <Button Content="Siguiente"
                                    Command="{Binding SiguienteCommand}"
                                    Margin="0,0,4,0"
                                    MinWidth="72"
                                    Style="{StaticResource BlueButtonStyle}" />
                            <Button Content="Final"
                                    Command="{Binding FinalCommand}"
                                    MinWidth="72"
                                    Style="{StaticResource BlueButtonStyle}" />
                        </StackPanel>

                        <!-- Puntajes obtenidos -->
                        <GroupBox Grid.Row="2"
                                  Header="Puntajes obtenidos:"
                                  Margin="0,0,0,0"
                                  Style="{StaticResource CardGroupBoxStyle}">
                            <Grid Margin="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <!-- Izquierda: actividades + inasistencias -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding NombreAlumno}"
                                               FontWeight="Bold"
                                               Foreground="#0F172A"
                                               Margin="0,0,0,6"
                                               FontSize="12" />

                                    <ItemsControl x:Name="PuntajesItemsControl" ItemsSource="{Binding Actividades}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="42" />
                                                        <ColumnDefinition Width="52" />
                                                        <ColumnDefinition Width="40" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Nombre}"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1E293B"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding PuntajeObtenido, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="24"
                                                             VerticalContentAlignment="Center"
                                                             HorizontalContentAlignment="Center"
                                                             FontSize="11"
                                                             Margin="1,0"
                                                             MaxLength="3"
                                                             Style="{StaticResource RoundedTextBoxStyle}"
                                                             PreviewTextInput="Numeros_PreviewTextInput"
                                                             DataObject.Pasting="Numeros_Pasting"
                                                             IsEnabled="{Binding IsPuntajeEditable}"
                                                             KeyDown="PuntajeObtenido_KeyDown"
                                                             TextChanged="Puntaje_TextChanged" />

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding FraccionTexto}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Foreground="#475569"
                                                               FontSize="12" />

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding ContribucionTexto}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"
                                                               FontWeight="Bold"
                                                               Foreground="#1B365D"
                                                               FontSize="12" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="{Binding LeyendaCapturaDirecta}"
                                               Foreground="#B91C1C"
                                               FontSize="12"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding AlumnoConCapturaDirecta, Converter={StaticResource BoolToVis}}" />

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,6,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Inasistencias:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1E293B"
                                                   FontSize="11" />
                                        <TextBox Width="50"
                                                 Height="24"
                                                 Text="{Binding Inasistencias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 MaxLength="3"
                                                 PreviewTextInput="NumerosEnteros_PreviewTextInput"
                                                 DataObject.Pasting="Numeros_Pasting"
                                                 TextChanged="Puntaje_TextChanged">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource RoundedTextBoxStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AsistenciaActiva}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AlumnoConCapturaDirecta}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Línea vertical -->
                                <Border Grid.Column="1"
                                        Width="1"
                                        Background="#D7DEE8"
                                        Margin="10,0" />

                                <!-- Derecha: calificación -->
                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Calificación"
                                               HorizontalAlignment="Center"
                                               Foreground="#334155"
                                               FontSize="15" />
                                    <TextBlock Text="Parcial:"
                                               HorizontalAlignment="Center"
                                               Foreground="#334155"
                                               FontSize="15"
                                               Margin="0,-1,0,0" />
                                    <Border Style="{StaticResource BlueGradeBlock}"
                                            Margin="0,6,0,0">
                                        <TextBox Text="{Binding CalificacionParcialTexto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource RoundedTextBoxStyle}"
                                                 FontSize="22"
                                                 FontWeight="Black"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Foreground="#1E3A8A"
                                                 Width="100"
                                                 IsEnabled="{Binding AlumnoConCapturaDirecta}"
                                                 TextChanged="CalificacionParcial_TextChanged" />
                                    </Border>
                                    <CheckBox Content="Calificación directa (solo este alumno)"
                                              IsChecked="{Binding AlumnoConCapturaDirecta, Mode=TwoWay}"
                                              Margin="0,8,0,0"
                                              ToolTip="Si está activado, este alumno tiene calificación directa y no se permite editar sus puntajes locales." />
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>