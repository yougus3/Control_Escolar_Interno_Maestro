<Window x:Class="Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views.ConfiguracionParcialesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración"
        Width="980"
        Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Configuración"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1B365D"
                   Margin="2,0,0,12" />

        <TabControl Grid.Row="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1">
            <TabItem Header="Parciales">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Activa o desactiva las evaluaciones visibles en el sistema"
                                   Foreground="#475569"
                                   FontSize="13"
                                   Margin="0,0,0,12" />

                        <CheckBox Content="P1"
                                  IsChecked="{Binding Parcial1Habilitado, Mode=TwoWay}"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <CheckBox Content="P2"
                                  IsChecked="{Binding Parcial2Habilitado, Mode=TwoWay}"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <CheckBox Content="P3"
                                  IsChecked="{Binding Parcial3Habilitado, Mode=TwoWay}"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />

                        <CheckBox Content="SEM"
                                  IsChecked="{Binding SemestralHabilitado, Mode=TwoWay}"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#D7DEE8"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,16,0,16">
                        <StackPanel>
                            <TextBlock Text="Los cambios se guardan en configuracion_parciales.json"
                                       Foreground="#64748B"
                                       FontSize="12" />
                            <TextBlock
                                Text="Al guardar, la pantalla principal se refresca con las evaluaciones activas."
                                Foreground="#64748B"
                                FontSize="12"
                                Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Guardar configuración"
                                Width="170"
                                Height="34"
                                Background="#1B365D"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Click="GuardarConfiguracion_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Calificación directa">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Materia:"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <ComboBox Width="300"
                                  Height="32"
                                  ItemsSource="{Binding MateriasDisponibles}"
                                  SelectedItem="{Binding MateriaSeleccionadaDirecta, Mode=TwoWay}"
                                  VerticalContentAlignment="Center" />

                        <TextBlock Text="Evaluación:"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontWeight="SemiBold"
                                   Margin="18,0,8,0" />
                        <ComboBox Width="120"
                                  Height="32"
                                  ItemsSource="{Binding EvaluacionesDisponiblesDirecta}"
                                  SelectedItem="{Binding EvaluacionSeleccionadaDirecta, Mode=TwoWay}"
                                  VerticalContentAlignment="Center" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="1.0*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Alumnos">
                            <ListBox ItemsSource="{Binding AlumnosDirectos}"
                                     SelectedItem="{Binding AlumnoSeleccionadoDirecto, Mode=TwoWay}"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Matricula}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1E293B"
                                                       FontSize="13" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Nombre}"
                                                       Foreground="#334155"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!--<TextBlock Grid.Column="2"
                                                       Text="{Binding ValorSeleccionado}"
                                                       HorizontalAlignment="Right"
                                                       FontWeight="Bold"
                                                       Foreground="#1B365D"
                                                       FontSize="13"/>-->
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="Edición">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Alumno seleccionado"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#1B365D"
                                           Margin="0,0,0,10" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding NombreAlumnoDirecto}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           Margin="0,0,0,4" />

                                <TextBlock Grid.Row="2"
                                           Text="{Binding MatriculaAlumnoDirecto}"
                                           Foreground="#475569"
                                           FontSize="12"
                                           Margin="0,0,0,2" />

                                <TextBlock Grid.Row="3"
                                           Text="{Binding GrupoAlumnoDirecto}"
                                           Foreground="#475569"
                                           FontSize="12"
                                           Margin="0,0,0,14" />

                                <StackPanel Grid.Row="4" Margin="0,0,0,10">
                                    <TextBlock Text="Calificación actual"
                                               Foreground="#475569"
                                               FontSize="12"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding CalificacionActualDirecta}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#1B365D" />
                                </StackPanel>

                                <StackPanel Grid.Row="5">
                                    <TextBlock Text="Nueva calificación"
                                               Foreground="#475569"
                                               FontSize="12"
                                               Margin="0,0,0,4" />
                                    <TextBox
                                        MaxLength="4"
                                        PreviewTextInput="Calificacion_PreviewTextInput"
                                        Text="{Binding CalificacionNuevaDirecta, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Acepta valores como 0, 8, 10 o 8.5"
                                               Foreground="#64748B"
                                               FontSize="11"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="6"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,14,0,0">
                                    <Button Content="Guardar"
                                            Width="140"
                                            Height="34"
                                            Background="#16A34A"
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Click="GuardarDirecta_Click" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding EstadoDirecto}"
                               Foreground="#64748B"
                               FontSize="12"
                               Margin="0,10,0,0" />
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cerrar"
                    Width="100"
                    Height="34"
                    Background="#E2E8F0"
                    Foreground="#0F172A"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="Cerrar_Click" />
        </StackPanel>
    </Grid>
</Window>