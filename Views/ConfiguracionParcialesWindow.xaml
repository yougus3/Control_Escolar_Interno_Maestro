<Window x:Class="Registro_de_Calificaciones_Jose_Ma._Morelos_y_Pavon.Views.ConfiguracionParcialesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de parciales"
        Height="290"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configuración de parciales"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#1B365D"
                   Margin="0,0,0,15"/>

        <CheckBox x:Name="chkCapturaDirecta"
                  Grid.Row="1"
                  Content="Captura directa"
                  Margin="0,0,0,10"/>

        <CheckBox x:Name="chkP1"
                  Grid.Row="2"
                  Content="Parcial 1"
                  Margin="0,0,0,8"/>

        <CheckBox x:Name="chkP2"
                  Grid.Row="3"
                  Content="Parcial 2"
                  Margin="0,0,0,8"/>

        <CheckBox x:Name="chkP3"
                  Grid.Row="4"
                  Content="Parcial 3"
                  Margin="0,0,0,8"/>

        <CheckBox x:Name="chkSEM"
                  Grid.Row="5"
                  Content="SEM"
                  Margin="0,0,0,8"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Cancelar"
                    Width="90"
                    Height="32"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click"/>
            <Button Content="Guardar"
                    Width="90"
                    Height="32"
                    Background="#16A34A"
                    Foreground="White"
                    Click="Guardar_Click"/>
        </StackPanel>
    </Grid>
</Window>